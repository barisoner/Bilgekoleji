@model IEnumerable<Panel>
@using StuWare.Helpers
@{
    ViewData["Title"] = "Anasayfa";
    var studentCount = ViewBag.StudentCount as int? ?? 0;
    var teacherCount = ViewBag.TeacherCount as int? ?? 0;
    var courseCount = ViewBag.CourseCount as int? ?? 0;
}

<div class="container-fluid px-0 px-md-2">
    <div class="row justify-content-center mx-0">
        <div class="col-12 col-xl-11 mx-auto" style="max-width: 1320px;">
            <div class="row mb-2 justify-content-center">
                <div class="col-12 col-md-4 col-lg-3 mb-3">
                    <div class="card border-0 shadow-sm bg-primary text-white h-100">
                        <div class="card-body d-flex flex-column" style="min-height: 8.5rem;">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <span class="text-uppercase small font-weight-bold" style="opacity: 0.9;">Toplam Öğrenci</span>
                                <span class="text-white flex-shrink-0 ml-2" style="opacity: 0.75;" aria-hidden="true">
                                    <svg width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/><path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/></svg>
                                </span>
                            </div>
                            <div class="mt-auto pt-2 w-100">
                                <p class="display-4 font-weight-bold mb-0 text-nowrap" style="line-height: 1.1;">@studentCount</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-3 mb-3">
                    <div class="card border-0 shadow-sm bg-success text-white h-100">
                        <div class="card-body d-flex flex-column" style="min-height: 8.5rem;">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <span class="text-uppercase small font-weight-bold" style="opacity: 0.9;">Aktif Eğitmenler</span>
                                <span class="text-white flex-shrink-0 ml-2" style="opacity: 0.75;" aria-hidden="true">
                                    <svg width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/></svg>
                                </span>
                            </div>
                            <div class="mt-auto pt-2 w-100">
                                <p class="display-4 font-weight-bold mb-0 text-nowrap" style="line-height: 1.1;">@teacherCount</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-3 mb-3">
                    <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                        <div class="card-body d-flex flex-column" style="min-height: 8.5rem;">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <span class="text-uppercase small font-weight-bold" style="opacity: 0.85;">Toplam Ders Sayısı</span>
                                <span class="flex-shrink-0 ml-2" style="opacity: 0.65;" aria-hidden="true">
                                    <svg width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .447.474c.896.196 2.183.828 3.171 1.434A1.5 1.5 0 0 0 5.5 15h5a1.5 1.5 0 0 0 1.3-.728 12.09 12.09 0 0 0 3.199-.956.5.5 0 0 0 .302-.819V2.5a.5.5 0 0 0-.42-.393A12.11 12.11 0 0 0 8 1.783z"/></svg>
                                </span>
                            </div>
                            <div class="mt-auto pt-2 w-100">
                                <p class="display-4 font-weight-bold mb-0 text-nowrap" style="line-height: 1.1;">@courseCount</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center py-3 px-3">
                <h1 class="display-4 font-weight-light text-dark mb-2">Hoş geldiniz</h1>
                <p class="lead text-muted mb-0">StuWare yönetim paneline hoş geldiniz. Sol menüden tanımlamalara ve diğer modüllere erişebilirsiniz.</p>
            </div>
        </div>
    </div>
</div>

<hr class="my-5" />

<div class="container-fluid px-0 px-md-2">
    <div class="row justify-content-center mx-0">
        <div class="col-12 col-xl-11 mx-auto" style="max-width: 1320px;">
            @if (Model != null)
            {
                @foreach (var item in Model)
                {
                    <div class="card-group mb-4">
                        <div class="card">
                            <img src="~/img/@item.Image" class="card-img-top" alt="" style="max-width: 100%; height: auto; object-fit: contain;" />
                            <div class="card-body">
                                <h5 class="card-title">@item.Title</h5>
                                <p class="card-text">@item.Description</p>
                                <p class="card-text"><small class="text-muted">Last updated @DateHelper.GetTimeAgo(item.UpdatedDate)</small></p>
                                <a asp-action="Details" asp-controller="Home" asp-route-id="@item.ID"><button type="button" class="btn btn-success">Update</button></a>
                                <form asp-action="Delete" asp-controller="Home" asp-route-id="@item.ID" method="post" class="d-inline js-panel-delete-form">
                                    <button type="button" class="btn btn-danger js-panel-delete-btn">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }

            <style>
                .btn-add-content-block {
                    transition: transform .18s ease, box-shadow .18s ease, color .18s ease, background-color .18s ease, border-color .18s ease;
                }
                .btn-add-content-block:hover,
                .btn-add-content-block:focus {
                    transform: scale(1.04);
                    box-shadow: 0 .35rem .75rem rgba(0, 86, 179, .28) !important;
                    color: #fff !important;
                    background-color: #007bff !important;
                    border-color: #007bff !important;
                }
            </style>
            <div class="text-center py-5">
                <a asp-action="Create" asp-controller="Home" class="btn btn-outline-primary btn-lg shadow-sm btn-add-content-block d-inline-flex align-items-center px-4">
                    <svg width="1.25em" height="1.25em" fill="currentColor" class="mr-2" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
                    </svg>
                    Yeni İçerik Bloğu Ekle
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            function confirmPanelDelete(form) {
                if (typeof Swal === 'undefined') {
                    if (confirm('Bloku silmek istediğinize emin misiniz?')) {
                        form.submit();
                    }
                    return;
                }
                Swal.fire({
                    title: 'Bloku Sil?',
                    html: '<p class="mb-2">Emin misiniz?</p><p class="mb-0">Bu işlem geri alınamaz!</p>',
                    icon: 'warning',
                    iconColor: '#f0ad4e',
                    showCancelButton: true,
                    confirmButtonText: 'Sil',
                    cancelButtonText: 'İptal',
                    reverseButtons: true,
                    focusCancel: true,
                    background: '#1a2332',
                    color: '#e8eef5',
                    confirmButtonColor: '#c0392b',
                    cancelButtonColor: '#2c3e5a',
                    customClass: {
                        popup: 'shadow border-0',
                        title: 'font-weight-bold',
                        confirmButton: 'font-weight-bold px-4',
                        cancelButton: 'font-weight-bold px-4'
                    }
                }).then(function (result) {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            }

            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.js-panel-delete-btn');
                if (!btn) return;
                var form = btn.closest('.js-panel-delete-form');
                if (!form) return;
                e.preventDefault();
                confirmPanelDelete(form);
            });
        })();
    </script>
}
